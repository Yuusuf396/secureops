# Supabase Postgres connection string (Settings -> Database -> Connection string, URI)
# Leave unset to run with an in-memory store for local dev.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Groq API key for AI summaries - free tier, no credit card (https://console.groq.com)
GROQ_API_KEY=gsk_...

# Optional
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
